# EntraMap — configuratie
# Kopieer naar .env en vul de waarden in.

# App registration (multi-tenant, zie README voor setup-instructies)
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=your-client-secret-here

# Willekeurige lange string voor Flask sessie-encryptie
# Genereer met: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Callback URL — pas aan naar je productie-domein
# REDIRECT_URI=https://entramap.azurewebsites.net/auth/callback
