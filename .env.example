# EntraMap configuration
# Copy this file to .env and fill in the values.

# App registration (multi-tenant, see README.md for setup instructions)
CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CLIENT_SECRET=your-client-secret-here

# Long random string used for Flask session encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Callback URL used during sign-in. This must match an Entra App Registration redirect URI exactly.
# Local dev example:
# REDIRECT_URI=http://localhost:5000/auth/callback
# Azure example:
# REDIRECT_URI=https://entramap.azurewebsites.net/auth/callback

# Optional: override server-side session file storage location.
# In Azure Linux this can be left empty (app defaults to /tmp).
# SESSION_FILE_DIR=/tmp/entramap_flask_session
